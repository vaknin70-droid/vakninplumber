---
import Base from "@/layouts/Base.astro";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer";
import BreadcrumbNav from "@/components/BreadcrumbNav";
import { History, Award, ShieldCheck, Clock, Hammer, Droplets, Waves, Flame, AlertTriangle, Search, CheckCircle2 } from "lucide-react";
import plumberWorking from "@/assets/plumber-working.jpg";
---

<Base 
  title="אודות ואקנין אינסטלציה — מעל 20 שנות ניסיון ומקצועיות" 
  description="ואקנין אינסטלציה - מומחים לפתרון תקלות מים וביוב מורכבות מעל 20 שנה. אמינות, שקיפות ועבודה נקייה ללא פשרות. שירות בפריסה ארצית."
>
  <Navbar client:load />
  
  <main>
    {/* Hero Section - Matching Screenshot Precisely */}
    <div class="relative bg-[#0f2757] pt-24 pb-16 md:pt-28 md:pb-20 lg:pt-36 lg:pb-24 overflow-hidden text-white">
      {/* Background decoration */}
      <div class="absolute inset-0 z-0 opacity-10">
         <div class="absolute inset-0 bg-[#0f2757]"></div>
      </div>

      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-primary/20 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/2"></div>
      </div>
      
      <div class="container px-6 md:px-12 relative z-10 w-full text-right">
        <div class="flex flex-col items-start w-full">
          <BreadcrumbNav 
            client:load
            items={[{ label: "ראשי", href: "/" }, { label: "אודות" }]} 
            className="opacity-70 mb-10"
          />
          <div class="max-w-4xl w-full text-right">
            <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-[58px] font-extrabold leading-tight mb-8">
              ואקנין אינסטלציה:
              <span class="block text-[#ee4b2b] mt-4 font-extrabold">מעל 20 שנה של<br/>מצוינות</span>
            </h1>
            <p class="text-lg md:text-xl lg:text-2xl text-white/90 leading-relaxed font-light max-w-2xl mt-8 mr-0 ml-auto">
              כבר למעלה משני עשורים שאנחנו פותרים את תקלות המים המורכבות ביותר, בבתים פרטיים ובמוסדות ברחבי הארץ. השקט הנפשי שלכם מתחיל כאן.
            </p>
          </div>
        </div>
      </div>

      <div class="absolute bottom-0 left-0 right-0 z-10 translate-y-1">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 100" class="w-full h-auto text-white fill-current">
          <path d="M0,80 C480,120 960,40 1440,80 L1440,100 L0,100 Z"></path>
        </svg>
      </div>
    </div>

    {/* Philosophy Section */}
    <section class="py-12 md:py-24 container px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-16 items-center">
        <div class="space-y-8 text-right order-2 lg:order-1 flex flex-col items-end">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-primary/10 text-primary">
            <History className="w-8 h-8" />
          </div>
          <h2 class="text-2xl md:text-3xl lg:text-4xl font-black text-[#0f2757]">המקצועיות היא השקט הנפשי שלכם</h2>
          <div class="space-y-4 md:space-y-6 text-base md:text-lg text-slate-600 leading-relaxed text-right">
            <p>
              אנחנו מאמינים שאינסטלציה היא הרבה מעבר לתיקון נזילה – היא הביטחון שלכם בבית. כעסק שהוקם על בסיס מקצועיות ללא פשרות, צברנו לאורך שני עשורים מוניטין של אמינות, שקיפות ועבודה נקייה.
            </p>
            <p class="font-bold text-[#0f2757] bg-blue-50/50 p-6 rounded-2xl border-r-4 border-[#0f2757]">
              אצלנו אין "בערך" ואין פתרונות זמניים. אנחנו מביאים איתנו מיומנות שנרכשה באלפי פרויקטים בשטח, כדי שאתם תוכלו לישון בשקט.
            </p>
          </div>
        </div>
        <div class="relative order-1 lg:order-2">
          <div class="absolute -inset-4 bg-primary/5 rounded-3xl -rotate-2"></div>
          <img 
            src={plumberWorking.src} 
            alt="עבודת אינסטלציה מקצועית" 
            class="relative z-10 rounded-2xl shadow-2xl border border-slate-100"
          />
          <div class="absolute -bottom-10 -right-10 bg-white/90 backdrop-blur-lg shadow-2xl p-8 rounded-3xl hidden md:block z-20 border border-white max-w-[220px] text-center transform hover:scale-105 transition-transform duration-300">
            <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-transparent rounded-3xl pointer-events-none"></div>
            <p class="relative text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-primary to-primary-dark mb-2 drop-shadow-sm">20+</p>
            <p class="relative text-sm font-bold text-slate-600 uppercase tracking-widest leading-snug">שנות ניסיון<br/>בשטח</p>
          </div>
        </div>
      </div>
    </section>

    {/* Manifesto Section */}
    <section class="py-24 container overflow-hidden">
      <div class="bg-[#0f2757] rounded-[2.5rem] p-12 lg:p-20 relative text-white overflow-hidden text-right">
         <div class="relative z-10">
           <div class="text-center mb-16">
             <h2 class="text-3xl md:text-5xl font-black mb-6">האמנה שלנו: אמינות היא המפתח</h2>
             <p class="text-white/70 text-lg max-w-2xl mx-auto leading-relaxed">
               אנחנו בואקנין אינסטלציה יודעים שהזמנת בעל מקצוע הביתה דורשת אמון. לכן, אנחנו מתחייבים ל:
             </p>
           </div>

           <div class="grid grid-cols-1 sm:grid-cols-2 gap-12 lg:gap-16 max-w-5xl mx-auto">
             {[
               { icon: Award, title: "מחירים הוגנים", desc: "הצעות מחיר שקופות ללא הפתעות בסיום העבודה." },
               { icon: Clock, title: "עמידה בזמנים", desc: "הזמן שלכם יקר לנו, ואקנין מקפידים על הגעה מהירה ומדויקת." },
               { icon: ShieldCheck, title: "איכות חומרים", desc: "שימוש אך ורק באביזרים מקוריים בעלי תו תקן ישראלי." },
               { icon: CheckCircle2, title: "אחריות מלאה", desc: "אנחנו עומדים מאחורי כל עבודה שאנחנו מבצעים." }
             ].map((item, idx) => {
               const Icon = item.icon;
               return (
                <div key={idx} class="flex gap-6 items-start flex-row-reverse text-right">
                  <div class="flex-shrink-0 w-14 h-14 rounded-2xl bg-white/10 flex items-center justify-center text-[#ee4b2b] shadow-inner border border-white/5">
                    <Icon className="w-7 h-7" />
                  </div>
                  <div>
                    <h4 class="text-xl md:text-2xl font-black mb-2">{item.title}</h4>
                    <p class="text-white/60 leading-relaxed text-lg">{item.desc}</p>
                  </div>
                </div>
               );
             })}
           </div>
         </div>
      </div>
    </section>
  </main>

  <Footer client:load />
</Base>
