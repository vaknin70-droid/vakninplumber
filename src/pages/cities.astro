---
import Base from "@/layouts/Base.astro";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer";
import { cityPages } from "@/data/cities";
import { MapPin } from "lucide-react";

const title = "אזורי שירות אינסטלציה - כל הערים | ואקנין אינסטלציה";
const description = "צפו בכל אזורי השירות שלנו. אנו מספקים שירותי אינסטלציה מקצועיים בתל אביב, רמת גן, גבעתיים, פתח תקווה וערים רבות נוספות באזור המרכז.";
---

<Base title={title} description={description}>
  <Navbar client:load />

  <main class="container px-4 sm:px-6 py-14 md:py-24">
    <div class="mx-auto max-w-4xl text-right">
      <div class="mb-10 md:mb-16 text-center">
        <h1 class="mb-4 md:mb-6 font-heading text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-foreground">אזורי שירות</h1>
        <p class="text-base md:text-xl text-muted-foreground">
          אנו מספקים שירותי אינסטלציה מקצועיים ומהירים בפריסה רחבה במרכז הארץ.
          בחרו את עירכם לקבלת פרטים נוספים ושירות אישי.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3">
        {cityPages.map((city) => (
          <a
            key={city.slug}
            href={`/city/${city.slug}`}
            class="group flex items-center justify-end gap-3 rounded-lg border bg-card p-4 transition-all duration-200 hover:bg-accent hover:text-accent-foreground no-underline text-foreground"
          >
            <span class="font-semibold">{city.name}</span>
            <MapPin className="h-5 w-5 text-primary group-hover:text-accent-foreground" />
          </a>
        ))}
      </div>

      <div class="mt-10 md:mt-20 rounded-2xl bg-primary p-5 md:p-8 text-center text-primary-foreground">
        <h2 class="mb-4 text-2xl font-bold">לא מצאתם את העיר שלכם?</h2>
        <p class="mb-6 opacity-90">צרו איתנו קשר עכשיו ובדקו אם אנחנו מגיעים גם אליכם.</p>
        <a
          href="tel:+972528126653"
          class="inline-flex h-12 items-center justify-center rounded-full bg-accent px-8 font-bold text-accent-foreground transition-colors hover:bg-accent/90 no-underline"
        >
          052-8126653 :התקשרו עכשיו
        </a>
      </div>
    </div>
  </main>

  <Footer client:load />
</Base>
