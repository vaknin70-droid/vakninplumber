---
import Base from "@/layouts/Base.astro";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer";

const title = "העמוד לא נמצא - 404 | ואקנין אינסטלציה";
---

<Base title={title}>
  <Navbar client:load />

  <main class="flex min-h-[70vh] items-center justify-center text-center">
    <div class="container px-4">
      <h1 class="mb-4 text-7xl font-black text-primary md:text-9xl">404</h1>
      <h2 class="mb-6 text-2xl font-bold md:text-3xl text-foreground">אופס! נראה שהלכתם לאיבוד בצנרת</h2>
      <p class="mb-10 text-lg text-muted-foreground">העמוד שחיפשתם לא קיים או שהועבר לכתובת אחרת.</p>
      <a
        href="/"
        class="inline-flex h-12 items-center justify-center rounded-full bg-primary px-8 font-bold text-primary-foreground transition-all hover:bg-primary/90 no-underline shadow-lg"
      >
        חזרה לדף הבית
      </a>
    </div>
  </main>

  <Footer client:load />
</Base>
