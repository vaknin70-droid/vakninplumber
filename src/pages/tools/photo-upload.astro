---
import Base from "@/layouts/Base.astro";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer";
import BreadcrumbNav from "@/components/BreadcrumbNav";
import PhotoUploadTool from "@/components/tools/PhotoUploadTool";

const title = "העלאת תמונה להערכת מחיר — ואקנין אינסטלציה";
const description = "צריכים הצעת מחיר מדויקת? העלו תמונה של התקלה והמומחים שלנו יחזרו אליכם עם הערכה והצעה מהירה.";
---

<Base title={title} description={description}>
  <Navbar client:load />

  <main class="container py-12 px-4 sm:px-6">
    <div class="flex flex-col items-end">
      <BreadcrumbNav
        client:load
        items={[
          { label: "ראשי", href: "/" },
          { label: "מרכז הכלים", href: "/tools-hub" },
          { label: "העלאת תמונה" },
        ]}
      />
      
      <div class="w-full max-w-4xl mx-auto mt-8">
        <PhotoUploadTool client:load />
      </div>
    </div>
  </main>

  <Footer client:load />
</Base>
