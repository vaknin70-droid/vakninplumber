---
import Base from "@/layouts/Base.astro";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer";
import BreadcrumbNav from "@/components/BreadcrumbNav";
import LeadCaptureBlock from "@/components/LeadCaptureBlock";
import BlogList from "@/components/BlogList";
import { blogPosts, getAllCategories } from "@/data/blog";
import { BookOpen } from "lucide-react";

const categories = getAllCategories();
---

<Base 
  title="בלוג אינסטלציה — טיפים ומדריכים מקצועיים | ואקנין אינסטלציה"
  description="מאמרים וטיפים מקצועיים בנושאי אינסטלציה, תחזוקת בית, נזילות ודוד שמש. הבלוג של ואקנין אינסטלציה."
>
  <Navbar client:load />

  {/* Hero */}
  <div class="relative bg-[#0f2757] pt-24 pb-16 md:pt-28 md:pb-20 lg:pt-36 lg:pb-24 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 md:w-[500px] md:h-[500px] bg-primary/20 rounded-full blur-[80px] md:blur-[100px] -translate-y-1/2 translate-x-1/3"></div>
    </div>

    <div class="container px-6 md:px-12 relative z-10 w-full text-right">
      <div class="flex flex-col items-start w-full">
        <BreadcrumbNav
          client:load
          items={[{ label: "ראשי", href: "/" }, { label: "בלוג" }]}
          className="mb-8 opacity-80"
        />
        <div class="max-w-3xl w-full text-right">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 md:px-4 md:py-2 rounded-full bg-white/10 border border-white/20 text-white/90 text-xs md:text-sm font-medium mb-6 direction-rtl mr-0 ml-auto">
            <BookOpen className="w-3.5 h-3.5 md:w-4 md:h-4 text-white" />
            <span>טיפים ומדריכים מקצועיים</span>
          </div>
          <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-[52px] font-extrabold text-white leading-tight mb-4 md:mb-6">
            הבלוג של
            <span class="block text-[#ee4b2b] mt-2">
              ואקנין אינסטלציה
            </span>
          </h1>
          <p class="text-base md:text-lg lg:text-xl text-white/80 leading-relaxed max-w-2xl font-light mr-0 ml-auto">
            מאמרים מקצועיים, טיפים חוסכי כסף ומדריכים פרקטיים — כתובים בשפה פשוטה, ישר משולחן האינסטלטורים שלנו.
          </p>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 translate-y-1">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 100" class="w-full h-auto text-slate-50 fill-current">
        <path d="M0,80 C480,120 960,40 1440,80 L1440,100 L0,100 Z"></path>
      </svg>
    </div>
  </div>

  <main class="container px-4 sm:px-6 py-10 md:py-16">
    <BlogList client:load posts={blogPosts} categories={categories} />
    <LeadCaptureBlock client:load />
  </main>

  <Footer client:load />
</Base>
