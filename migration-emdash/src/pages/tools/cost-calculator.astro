---
import Base from "@/layouts/Base.astro";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer";
import BreadcrumbNav from "@/components/BreadcrumbNav";
import CostCalculator from "@/components/tools/CostCalculator";

const title = "מחשבון עלויות אינסטלציה — ואקנין אינסטלציה";
const description = "קבלו הערכת מחיר מיידית ומדויקת לתיקוני אינסטלציה שונים באמצעות המחשבון החכם שלנו.";
---

<Base title={title} description={description}>
  <Navbar client:load />

  <main class="container py-12 px-4 sm:px-6">
    <div class="flex flex-col items-end">
      <BreadcrumbNav
        client:load
        items={[
          { label: "ראשי", href: "/" },
          { label: "מרכז הכלים", href: "/tools-hub" },
          { label: "מחשבון עלויות" },
        ]}
      />
      
      <div class="w-full max-w-4xl mx-auto mt-8">
        <CostCalculator client:load />
      </div>
    </div>
  </main>

  <Footer client:load />
</Base>
