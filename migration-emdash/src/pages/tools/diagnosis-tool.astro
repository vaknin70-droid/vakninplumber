---
import Base from "@/layouts/Base.astro";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer";
import BreadcrumbNav from "@/components/BreadcrumbNav";
import DiagnosisTool from "@/components/tools/DiagnosisTool";

const title = "אבחון תקלות אינסטלציה — ואקנין אינסטלציה";
const description = "השתמשו בכלי האבחון החכם שלנו כדי לזהות את הבעיה בצנרת הביתית שלכם ולקבל פתרונות ראשוניים.";
---

<Base title={title} description={description}>
  <Navbar client:load />

  <main class="container py-12 px-4 sm:px-6">
    <div class="flex flex-col items-end">
      <BreadcrumbNav
        client:load
        items={[
          { label: "ראשי", href: "/" },
          { label: "מרכז הכלים", href: "/tools-hub" },
          { label: "אבחון תקלות" },
        ]}
      />
      
      <div class="w-full max-w-4xl mx-auto mt-8">
        <DiagnosisTool client:load />
      </div>
    </div>
  </main>

  <Footer client:load />
</Base>
