---
import Base from "@/layouts/Base.astro";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer";
import BreadcrumbNav from "@/components/BreadcrumbNav";
import EmergencyChecker from "@/components/tools/EmergencyChecker";

const title = "בדיקת דחיפות (חירום) — ואקנין אינסטלציה";
const description = "האם התקלה שלכם דורשת אינסטלטור עכשיו? בדקו את רמת הדחיפות של הבעיה שלכם בבודק החירום שלנו.";
---

<Base title={title} description={description}>
  <Navbar client:load />

  <main class="container py-12 px-4 sm:px-6">
    <div class="flex flex-col items-end">
      <BreadcrumbNav
        client:load
        items={[
          { label: "ראשי", href: "/" },
          { label: "מרכז הכלים", href: "/tools-hub" },
          { label: "בודק חירום" },
        ]}
      />
      
      <div class="w-full max-w-4xl mx-auto mt-8">
        <EmergencyChecker client:load />
      </div>
    </div>
  </main>

  <Footer client:load />
</Base>
