---
import Base from "@/layouts/Base.astro";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer";
import BreadcrumbNav from "@/components/BreadcrumbNav";
import LeadCaptureBlock from "@/components/LeadCaptureBlock";
import { getCityBySlug, cityPages } from "@/data/cities";
import { Phone, MessageCircle, CheckCircle2, MapPin, Clock, Shield } from "lucide-react";
import { Button } from "@/components/ui/button";

export function getStaticPaths() {
  return cityPages.map((city) => ({
    params: { slug: city.slug },
    props: { city },
  }));
}

const { city } = Astro.props;

if (!city) {
  return Astro.redirect("/");
}

const otherCities = cityPages.filter((c) => c.slug !== city.slug).slice(0, 6);

const services = [
  "פתיחת סתימות",
  "תיקון נזילות",
  "איתור נזילות סמויות",
  "תיקון והחלפת צנרת",
  "תיקון דוד שמש",
  "התקנת אינסטלציה",
  "שירות מהיר לתקלות דחופות",
  "תיקון אסלות",
];

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "Plumber",
  name: `ואקנין אינסטלציה - ${city.name}`,
  description: city.metaDescription,
  telephone: "+972528126653",
  url: `https://vaknin-plumbing.co.il/city/${city.slug}`,
  areaServed: { "@type": "City", name: city.name },
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
    opens: "07:00",
    closes: "22:00",
  },
};
---

<Base title={city.title} description={city.metaDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

  <Navbar client:load />

  <main>
    <section class="bg-primary/5 py-12 md:py-16">
      <div class="container px-4 sm:px-6">
        <BreadcrumbNav
          client:load
          items={[
            { label: "ראשי", href: "/" },
            { label: "אזורי שירות", href: "/#areas" },
            { label: city.name },
          ]}
        />
        <h1 class="mb-3 md:mb-4 font-heading text-xl sm:text-2xl md:text-4xl lg:text-5xl font-bold text-foreground leading-tight">{city.h1}</h1>
        <p class="mb-6 md:mb-8 max-w-2xl text-sm md:text-lg text-muted-foreground">{city.intro}</p>
        <div class="flex flex-col gap-4 sm:flex-row">
          <Button variant="hero" size="xl" client:load asChild>
            <a href="tel:+972528126653">
              <Phone className="h-5 w-5" />
              התקשרו עכשיו
            </a>
          </Button>
          <Button variant="hero-outline" size="xl" client:load className="border-accent text-accent hover:bg-accent/10" asChild>
            <a href="https://wa.me/972528126653" target="_blank" rel="noopener noreferrer">
              <MessageCircle className="h-5 w-5" />
              ווטסאפ
            </a>
          </Button>
        </div>
      </div>
    </section>

    <section class="container px-4 sm:px-6 py-10 md:py-16">
      <div class="mb-8 md:mb-12 rounded-2xl border border-primary/15 bg-primary/5 p-5 md:p-8 text-center">
        <h2 class="mb-3 font-heading text-2xl font-bold text-foreground md:text-3xl">{city.emergencyH2}</h2>
        <p class="mb-4 text-muted-foreground">
          הגעה מהירה לכל אזור ב{city.name}, אבחון מקצועי ופתרון מסודר עם ציוד מתקדם.
        </p>
        <Button variant="hero" size="xl" client:load asChild>
          <a href="tel:+972528126653">
            <Phone className="h-5 w-5" />
            דברו איתנו
          </a>
        </Button>
      </div>

      <div class="mb-10 md:mb-16 grid grid-cols-1 gap-3 md:gap-6 md:grid-cols-3">
        <div class="flex items-start gap-4 rounded-xl border border-border bg-card p-6">
          <Clock className="h-8 w-8 flex-shrink-0 text-primary" />
          <div>
            <h3 class="font-heading font-bold text-foreground border-none m-0">הגעה מהירה</h3>
            <p class="text-sm text-muted-foreground m-0">מענה מהיר לכל מקום ב{city.name}</p>
          </div>
        </div>
        <div class="flex items-start gap-4 rounded-xl border border-border bg-card p-6">
          <Shield className="h-8 w-8 flex-shrink-0 text-primary" />
          <div>
            <h3 class="font-heading font-bold text-foreground border-none m-0">אחריות על העבודה</h3>
            <p class="text-sm text-muted-foreground m-0">ביטוח מלא ואחריות עד שנה</p>
          </div>
        </div>
        <div class="flex items-start gap-4 rounded-xl border border-border bg-card p-6">
          <MapPin className="h-8 w-8 flex-shrink-0 text-primary" />
          <div>
            <h3 class="font-heading font-bold text-foreground border-none m-0">מכירים את האזור</h3>
            <p class="text-sm text-muted-foreground m-0">{city.areaDescription}</p>
          </div>
        </div>
      </div>

      <section class="mb-16">
        <h2 class="mb-6 font-heading text-2xl font-bold text-foreground">שירותי אינסטלציה ב{city.name}</h2>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          {services.map((s) => (
            <div key={s} class="flex items-center gap-3 rounded-lg bg-secondary p-4">
              <CheckCircle2 className="h-5 w-5 flex-shrink-0 text-primary" />
              <span class="font-medium text-foreground">{s}</span>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-16">
        <h2 class="mb-6 font-heading text-2xl font-bold text-foreground">שכונות שאנו משרתים ב{city.name}</h2>
        <div class="flex flex-wrap gap-3">
          {city.neighborhoods.map((n) => (
            <span key={n} class="rounded-full bg-primary/10 px-4 py-2 text-sm font-medium text-primary">
              {n}
            </span>
          ))}
        </div>
      </section>

      <LeadCaptureBlock client:load />

      <section class="mt-12">
        <h2 class="mb-4 font-heading text-xl font-bold text-foreground">אזורי שירות נוספים</h2>
        <div class="flex flex-wrap gap-3">
          {otherCities.map((c) => (
            <a
              key={c.slug}
              href={`/city/${c.slug}`}
              class="rounded-full bg-secondary px-4 py-2 text-sm text-foreground transition-colors hover:bg-primary/10 hover:text-primary no-underline"
            >
              {`אינסטלטור ב${c.name}`}
            </a>
          ))}
        </div>
      </section>
    </section>
  </main>

  <Footer client:load />
</Base>
