---
import Base from "@/layouts/Base.astro";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer";
import ToolsSection from "@/components/ToolsSection";
import { Sparkles } from "lucide-react";

const title = "כלים מקצועיים לאבחון ותיקון — ואקנין אינסטלציה";
const description = "השתמשו בכלים המקצועיים שלנו בחינם: מחשבון עלויות, אבחון תקלות, ובדיקת חירום.";
---

<Base title={title} description={description}>
  <Navbar client:load />

  <main>
    {/* Hero Section */}
    <section class="relative pt-32 pb-24 md:pt-40 md:pb-32 overflow-hidden bg-primary-dark text-white">
      <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/3 w-[800px] h-[800px] bg-primary/30 rounded-full blur-3xl opacity-50"></div>
      <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/3 w-[600px] h-[600px] bg-accent/20 rounded-full blur-3xl opacity-50"></div>
      
      <div class="container relative z-10 text-center">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md border border-white/20 px-4 py-2 rounded-full text-sm font-bold text-white mb-6 animate-fade-in">
          <Sparkles className="w-4 h-4 text-accent" />
          כלים דיגיטליים מתקדמים
        </div>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-black mb-6 leading-tight drop-shadow-lg">
          מרכז הכלים המקצועי
          <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-orange-300">
            של ואקנין אינסטלציה
          </span>
        </h1>
        
        <p class="text-xl md:text-2xl text-white/80 leading-relaxed max-w-2xl mx-auto font-medium">
          ריכזנו עבורכם את כל הכלים הדרושים כדי להבין את הבעיה ולהעריך עלויות — הכל בחינם.
        </p>
      </div>
      
      <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none z-20 translate-y-1">
        <svg class="relative block w-[calc(100%+1.3px)] h-[80px] md:h-[120px]" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
          <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,121.3,201.27,112.5,242.06,107.56,282.72,83.05,321.39,56.44Z" class="fill-slate-50"></path>
        </svg>
      </div>
    </section>

    <div class="bg-slate-50 relative z-20 pb-20">
      <ToolsSection client:load hideHeader={true} />
    </div>
  </main>

  <Footer client:load />

</Base>
