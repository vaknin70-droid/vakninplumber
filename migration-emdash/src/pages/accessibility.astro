---
import Base from "@/layouts/Base.astro";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer";

const title = "הצהרת נגישות — ואקנין אינסטלציה";
const description = "הצהרת הנגישות של ואקנין אינסטלציה — מחויבותנו להנגשת האתר לכלל האוכלוסייה.";
const today = new Date().toLocaleDateString("he-IL");
---

<Base title={title} description={description}>
  <Navbar client:load />

  <main class="py-16 bg-background min-h-screen px-4 sm:px-6">
    <div class="container max-w-3xl text-right">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-foreground mb-8">הצהרת נגישות</h1>
      <p class="text-muted-foreground mb-6">עדכון אחרון: {today}</p>

      <div class="space-y-8 text-foreground/90 leading-relaxed">
        <section>
          <h2 class="font-heading text-xl font-semibold text-foreground mb-3">מחויבותנו לנגישות</h2>
          <p>
            ואקנין אינסטלציה מחויבת לאפשר לכל אדם, לרבות אנשים עם מוגבלויות, להשתמש באתר בצורה נוחה ושוויונית.
            אנו פועלים להתאים את האתר לתקן הישראלי (ת"י 5568) ולהנחיות WCAG 2.1 ברמה AA.
          </p>
        </section>

        <section>
          <h2 class="font-heading text-xl font-semibold text-foreground mb-3">התאמות הנגישות שבוצעו</h2>
          <ul class="list-disc pr-6 space-y-2">
            <li>תפריט נגישות מובנה באתר לשינוי גודל גופן, ניגודיות צבעים והדגשת קישורים</li>
            <li>תמיכה בניווט מלא באמצעות מקלדת</li>
            <li>תוויות ותיאורים חלופיים (alt text) לתמונות</li>
            <li>מבנה כותרות היררכי ונכון (H1-H6)</li>
            <li>ניגודיות צבעים מספקת בין טקסט לרקע</li>
            <li>תמיכה בקוראי מסך</li>
            <li>אתר רספונסיבי המותאם למכשירים ניידים</li>
          </ul>
        </section>

        <section>
          <h2 class="font-heading text-xl font-semibold text-foreground mb-3">נתקלתם בבעיית נגישות?</h2>
          <p>
            אנו ממשיכים לפעול לשיפור נגישות האתר. אם נתקלתם בבעיה או שיש לכם הצעה לשיפור, 
            נשמח לשמוע:
          </p>
          <ul class="list-none space-y-2 mt-3 p-0">
            <li>📞 טלפון: <a href="tel:+972528126653" class="text-primary hover:underline font-semibold">052-8126653</a></li>
            <li>📧 אימייל: <a href="mailto:info@vaknin-plumbing.co.il" class="text-primary hover:underline font-semibold">info@vaknin-plumbing.co.il</a></li>
          </ul>
        </section>
      </div>
    </div>
  </main>

  <Footer client:load />
</Base>
