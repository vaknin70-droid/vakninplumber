---
import Base from "@/layouts/Base.astro";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer";
import ContactSection from "@/components/ContactSection";

const title = "צור קשר - ואקנין אינסטלציה | ייעוץ, אבחון והצעת מחיר";
const description = "צרו קשר עם ואקנין אינסטלציה לקבלת ייעוץ, אבחון והצעת מחיר. זמינים בטלפון, בווטסאפ ובמייל לשירות מקצועי באזור המרכז.";
---

<Base title={title} description={description}>
  <Navbar client:load />

  <main class="bg-slate-50 min-h-screen">
    <ContactSection client:load />
  </main>

  <Footer client:load />
</Base>
